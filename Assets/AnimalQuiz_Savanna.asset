  m_Script: {fileID: 11500000, guid: e3ddab126962d204d98fdf9055dbe530, type: 3}
  m_Name: AnimalQuiz_Savanna
  m_EditorClassIdentifier: 
  levelID: 1
  levelName: Savanna
  questions:
  - question: 'Bagaimana gajah berkomunikasi jarak jauh tanpa terdengar manusia?

      A.
      Melalui suara infrasonik dan getaran tanah

      B. Menggunakan sinyal cahaya
      dari telinga

      C. Mengeluarkan aroma khusus dari belalai'
    answerA: A
    answerB: B
    answerC: C
    correctAnswer: A
  - question: 'Berapa tekanan darah jerapah di jantung untuk memompa darah ke otak?

      A.
      120/80 (sama seperti manusia)

      B. 220/180 (dua kali lipat manusia)

      C.
      300/200 (tiga kali lipat manusia)'
    answerA: A
    answerB: B
    answerC: C
    correctAnswer: B
  - question: 'Berapa lama singa bisa tidur dalam sehari?

      A. 8-10 jam

      B.
      12-14 jam

      C. 16-20 jam'
    answerA: A
    answerB: B
    answerC: C
    correctAnswer: C
  - question: 'Apa fungsi utama garis-garis pada tubuh zebra?

      A. Menarik perhatian
      lawan jenis

      B. Mengusir lalat penggigit dan serangga

      C. Menyamarkan
      diri di padang rumput'
    answerA: A
    answerB: B
    answerC: C
    correctAnswer: B
